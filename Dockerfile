# clean base image containing only comfyui, comfy-cli and comfyui-manager
FROM runpod/worker-comfyui:5.8.4-base

# build-time tokens for gated downloads — never baked into final image.
# pass via: docker build --build-arg HF_TOKEN=$HF_TOKEN ...
ARG HF_TOKEN=""

# install custom nodes into comfyui
RUN comfy node install --exit-on-fail comfyui-impact-subpack@1.3.2 --mode remote || (echo "WARN: comfyui-impact-subpack@1.3.2 unavailable in registry, falling back to latest" >&2 && comfy node install --exit-on-fail comfyui-impact-subpack --mode remote)
RUN git clone https://github.com/ltdrdata/ComfyUI-Impact-Pack /comfyui/custom_nodes/ComfyUI-Impact-Pack && cd /comfyui/custom_nodes/ComfyUI-Impact-Pack && (git checkout cd34cfdd638a996fd011be1b490c70a7e0fb505f 2>/dev/null || (git fetch origin cd34cfdd638a996fd011be1b490c70a7e0fb505f --depth=1 && git checkout cd34cfdd638a996fd011be1b490c70a7e0fb505f) || echo "WARN: commit cd34cfdd638a996fd011be1b490c70a7e0fb505f unreachable in https://github.com/ltdrdata/ComfyUI-Impact-Pack, falling back to default branch HEAD")
RUN git clone https://github.com/rgthree/rgthree-comfy /comfyui/custom_nodes/rgthree-comfy && cd /comfyui/custom_nodes/rgthree-comfy && (git checkout 84a146fee39f7b3a8c6631dcac29bc13b077eb49 2>/dev/null || (git fetch origin 84a146fee39f7b3a8c6631dcac29bc13b077eb49 --depth=1 && git checkout 84a146fee39f7b3a8c6631dcac29bc13b077eb49) || echo "WARN: commit 84a146fee39f7b3a8c6631dcac29bc13b077eb49 unreachable in https://github.com/rgthree/rgthree-comfy, falling back to default branch HEAD")
RUN git clone https://github.com/cubiq/ComfyUI_essentials /comfyui/custom_nodes/ComfyUI_essentials && cd /comfyui/custom_nodes/ComfyUI_essentials && (git checkout 33ff89fd354d8ec3ab6affb605a79a931b445d99 2>/dev/null || (git fetch origin 33ff89fd354d8ec3ab6affb605a79a931b445d99 --depth=1 && git checkout 33ff89fd354d8ec3ab6affb605a79a931b445d99) || echo "WARN: commit 33ff89fd354d8ec3ab6affb605a79a931b445d99 unreachable in https://github.com/cubiq/ComfyUI_essentials, falling back to default branch HEAD")

# download models into comfyui
RUN BACKOFFS="10 20 30 60 90" && for i in 1 2 3 4 5; do comfy model download --url 'https://cool-anteater-319.convex.cloud/api/storage/2ec89a45-2b37-4d57-9026-9f1894d4a1c6' --relative-path models/ultralytics --filename 'bbox/face_yolov8m.pt' && break; if [ $i -eq 5 ]; then echo "model-download failed after 5 attempts" >&2; exit 1; fi; SLEEP=$(echo $BACKOFFS | cut -d ' ' -f $i) && echo "model-download attempt $i failed; retrying in $SLEEP seconds" >&2; sleep $SLEEP; done
RUN BACKOFFS="10 20 30 60 90" && for i in 1 2 3 4 5; do comfy model download --url 'https://dl.fbaipublicfiles.com/segment_anything/sam_vit_b_01ec64.pth' --relative-path models/ultralytics --filename 'sam_vit_b_01ec64.pth' && break; if [ $i -eq 5 ]; then echo "model-download failed after 5 attempts" >&2; exit 1; fi; SLEEP=$(echo $BACKOFFS | cut -d ' ' -f $i) && echo "model-download attempt $i failed; retrying in $SLEEP seconds" >&2; sleep $SLEEP; done
RUN BACKOFFS="10 20 30 60 90" && for i in 1 2 3 4 5; do HF_TOKEN=$HF_TOKEN comfy model download --url 'https://huggingface.co/boopyfloopy/gonzalomoXLFluxPony_v40UnityXLDMD/resolve/main/gonzalomoXLFluxPony_v40UnityXLDMD.safetensors' --relative-path models/checkpoints --filename 'gonzalomoXLFluxPony_v40UnityXLDMD.safetensors' && break; if [ $i -eq 5 ]; then echo "model-download failed after 5 attempts" >&2; exit 1; fi; SLEEP=$(echo $BACKOFFS | cut -d ' ' -f $i) && echo "model-download attempt $i failed; retrying in $SLEEP seconds" >&2; sleep $SLEEP; done
RUN BACKOFFS="10 20 30 60 90" && for i in 1 2 3 4 5; do HF_TOKEN=$HF_TOKEN comfy model download --url 'https://huggingface.co/gbrx/GonzaLomo/resolve/main/gonzalomoXLFluxPony_v10FluxSAIO.safetensors' --relative-path models/checkpoints --filename 'gonzalomoXLFluxPony_v10FluxSAIO.safetensors' && break; if [ $i -eq 5 ]; then echo "model-download failed after 5 attempts" >&2; exit 1; fi; SLEEP=$(echo $BACKOFFS | cut -d ' ' -f $i) && echo "model-download attempt $i failed; retrying in $SLEEP seconds" >&2; sleep $SLEEP; done
